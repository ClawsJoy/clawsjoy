<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Joy Mate - 智能助手</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
        }
        .header {
            text-align: center;
            color: white;
            margin-bottom: 30px;
        }
        .header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }
        .chat-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            overflow: hidden;
        }
        .messages {
            height: 400px;
            overflow-y: auto;
            padding: 20px;
            background: #f8f9fa;
        }
        .message {
            margin-bottom: 15px;
            display: flex;
        }
        .message.user {
            justify-content: flex-end;
        }
        .message.bot {
            justify-content: flex-start;
        }
        .message-content {
            max-width: 70%;
            padding: 10px 15px;
            border-radius: 18px;
            word-wrap: break-word;
        }
        .user .message-content {
            background: #667eea;
            color: white;
            border-bottom-right-radius: 4px;
        }
        .bot .message-content {
            background: #e9ecef;
            color: #333;
            border-bottom-left-radius: 4px;
        }
        .input-area {
            display: flex;
            padding: 20px;
            background: white;
            border-top: 1px solid #eee;
            gap: 10px;
        }
        .input-area input {
            flex: 1;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 25px;
            font-size: 14px;
            outline: none;
        }
        .input-area input:focus {
            border-color: #667eea;
        }
        .input-area button {
            padding: 12px 24px;
            background: #667eea;
            color: white;
            border: none;
            border-radius: 25px;
            cursor: pointer;
            font-size: 14px;
        }
        .input-area button:hover {
            background: #5a67d8;
        }
        .status {
            text-align: center;
            padding: 10px;
            font-size: 12px;
            color: #666;
            background: #f8f9fa;
        }
        .nav-links {
            text-align: center;
            margin-top: 20px;
        }
        .nav-links a {
            color: white;
            margin: 0 10px;
            text-decoration: none;
            opacity: 0.8;
        }
        .nav-links a:hover {
            opacity: 1;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🦞 Joy Mate</h1>
            <p>你的智能助手</p>
        </div>
        
        <div class="chat-card">
            <div class="messages" id="messages">
                <div class="message bot">
                    <div class="message-content">👋 你好！我是 Joy Mate，有什么可以帮你的？</div>
                </div>
            </div>
            
            <div class="input-area">
                <input type="text" id="messageInput" placeholder="输入消息..." onkeypress="if(event.keyCode===13)sendMessage()">
                <button onclick="sendMessage()">发送</button>
            </div>
            
            <div class="status" id="status">
                <span id="statusText">✅ 服务正常</span>
            </div>
        </div>
        
        <div class="nav-links">
            <a href="index.html">💬 对话</a>
            <a href="editor.html">✏️ 编辑器</a>
            <a href="library.html">📁 资料库</a>
            <a href="/index.html">🏠 首页</a>
        </div>
    </div>

    <script>
        // 正确的 API 地址
        const API_URL = 'http://localhost:8101/api/agent';
        
        async function sendMessage() {
            const input = document.getElementById('messageInput');
            const message = input.value.trim();
            
            if (!message) return;
            
            // 显示用户消息
            addMessage(message, 'user');
            input.value = '';
            
            // 显示加载状态
            document.getElementById('statusText').innerHTML = '⏳ AI 思考中...';
            
            try {
                const response = await fetch(API_URL, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    // 注意：请求体使用 text 字段
                    body: JSON.stringify({ text: message })
                });
                
                if (response.ok) {
                    const data = await response.json();
                    const reply = data.message || data.response || '收到回复';
                    addMessage(reply, 'bot');
                    document.getElementById('statusText').innerHTML = '✅ 服务正常';
                } else {
                    const errorText = await response.text();
                    console.error('API错误:', response.status, errorText);
                    addMessage(`服务错误 (${response.status})`, 'bot');
                    document.getElementById('statusText').innerHTML = '⚠️ 服务异常';
                }
            } catch (error) {
                console.error('网络错误:', error);
                addMessage('网络错误: ' + error.message, 'bot');
                document.getElementById('statusText').innerHTML = '❌ 连接失败';
            }
        }
        
        function addMessage(text, type) {
            const messagesDiv = document.getElementById('messages');
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${type}`;
            messageDiv.innerHTML = `<div class="message-content">${escapeHtml(text)}</div>`;
            messagesDiv.appendChild(messageDiv);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }
        
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        // 检查服务状态
        async function checkStatus() {
            try {
                const response = await fetch(API_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: 'ping' })
                });
                if (response.ok) {
                    document.getElementById('statusText').innerHTML = '✅ 服务正常';
                } else {
                    document.getElementById('statusText').innerHTML = '⚠️ 服务异常';
                }
            } catch (error) {
                document.getElementById('statusText').innerHTML = '❌ 连接失败';
            }
        }
        
        // 每30秒检查一次状态
        setInterval(checkStatus, 30000);
        
        // 页面加载时检查一次
        setTimeout(checkStatus, 1000);
    </script>
</body>
</html>
