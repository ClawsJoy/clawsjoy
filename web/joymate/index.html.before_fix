<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Joy Mate</title>
    <style>
        body { font-family: system-ui; padding: 20px; background: #0a0a14; color: #fff; }
        .chat { border: 1px solid #333; height: 400px; overflow-y: auto; padding: 10px; margin-bottom: 10px; }
        .input-area { display: flex; gap: 10px; margin-top: 10px; }
        input { flex: 1; padding: 10px; border-radius: 8px; border: 1px solid #333; background: #1a1a2e; color: #fff; }
        button { padding: 10px 20px; background: #667eea; border: none; border-radius: 8px; cursor: pointer; }
        a { color: #667eea; text-decoration: none; margin-left: 10px; }
        .msg { padding: 8px; margin: 4px 0; border-radius: 8px; }
        .user { background: #667eea; text-align: right; }
        .bot { background: #2a2a3e; }
    </style>
</head>
<body>
    <h1>🦞 Joy Mate</h1>
    <div class="chat" id="chat"></div>
    <div class="input-area">
        <input type="text" id="textInput" placeholder="输入消息..." onkeypress="if(event.keyCode===13)sendMsg()">
        <button onclick="sendMsg()">发送</button>
        <a href="/joymate/library.html?tenant=1" target="_blank">📁 我的资料库</a>
    </div>
    <script>
        const tenantId = new URLSearchParams(location.search).get('tenant') || '1';
        const API_BASE = 'http://localhost:8084';
        
        function addMsg(role, text) {
            const chat = document.getElementById('chat');
            const div = document.createElement('div');
            div.className = `msg ${role}`;
            div.innerText = `${role === 'user' ? '我' : 'AI'}: ${text}`;
            chat.appendChild(div);
            div.scrollIntoView();
        }
        
        async function sendMsg() {
            const input = document.getElementById('textInput');
            const text = input.value.trim();
            if (!text) return;
            addMsg('user', text);
            input.value = '';
            
            try {
                const res = await fetch(`${API_BASE}/api/chat`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: text, tenant_id: tenantId })
                });
                const data = await res.json();
                addMsg('bot', data.message || '收到');
            } catch(e) {
                addMsg('bot', '网络错误: ' + e.message);
            }
        }
        
        addMsg('bot', '你好！我是 Joy Mate，有什么可以帮你的？');
    </script>
</body>
</html>
