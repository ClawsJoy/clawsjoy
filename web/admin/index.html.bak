<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ClawsJoy 管理员中心</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .container { max-width: 1400px; margin: 0 auto; }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 15px;
        }
        h1 { color: #667eea; font-size: 28px; }
        .refresh-btn {
            background: #667eea;
            border: none;
            padding: 10px 24px;
            border-radius: 8px;
            color: white;
            cursor: pointer;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .stat-card {
            background: rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            backdrop-filter: blur(10px);
        }
        .stat-number {
            font-size: 36px;
            font-weight: bold;
            color: #667eea;
        }
        .stat-label {
            font-size: 12px;
            color: #aaa;
            margin-top: 5px;
        }
        .panel {
            background: rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 20px;
        }
        .panel-title {
            font-size: 18px;
            font-weight: bold;
            color: #fff;
            margin-bottom: 15px;
            border-bottom: 1px solid rgba(255,255,255,0.2);
            padding-bottom: 10px;
        }
        .agent-table {
            width: 100%;
            border-collapse: collapse;
        }
        .agent-table th, .agent-table td {
            padding: 10px;
            text-align: left;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            color: #ccc;
        }
        .agent-table th { color: #667eea; }
        .progress-bar {
            background: rgba(255,255,255,0.2);
            border-radius: 10px;
            height: 20px;
            overflow: hidden;
        }
        .progress-fill {
            background: #10b981;
            height: 100%;
            border-radius: 10px;
            transition: width 0.3s;
        }
        .task-list {
            max-height: 300px;
            overflow-y: auto;
        }
        .task-item {
            padding: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .task-item:hover { background: rgba(255,255,255,0.05); }
        .task-status {
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
        }
        .status-pending { background: #f59e0b; }
        .status-approved { background: #10b981; }
        .status-rejected { background: #ef4444; }
        .btn-link {
            background: #667eea;
            border: none;
            padding: 5px 12px;
            border-radius: 6px;
            color: white;
            cursor: pointer;
            text-decoration: none;
            font-size: 12px;
        }
        .btn-link:hover { opacity: 0.8; }
        .nav-links {
            display: flex;
            gap: 15px;
            margin-top: 20px;
            flex-wrap: wrap;
        }
        .nav-card {
            background: rgba(102,126,234,0.2);
            border-radius: 12px;
            padding: 15px 25px;
            text-decoration: none;
            color: white;
            text-align: center;
            flex: 1;
            min-width: 150px;
            transition: 0.2s;
        }
        .nav-card:hover { background: rgba(102,126,234,0.4); transform: translateY(-2px); }
        .nav-icon { font-size: 32px; margin-bottom: 8px; }
        .nav-title { font-weight: bold; }
        .nav-desc { font-size: 11px; color: #aaa; margin-top: 5px; }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>👑 ClawsJoy 管理员中心</h1>
        <button class="refresh-btn" onclick="loadAllData()">🔄 刷新数据</button>
    </div>

    <!-- 统计概览 -->
    <div class="stats-grid" id="statsGrid">
        <div class="stat-card"><div class="stat-number" id="totalTasks">-</div><div class="stat-label">总任务</div></div>
        <div class="stat-card"><div class="stat-number" id="pendingTasks">-</div><div class="stat-label">待审核</div></div>
        <div class="stat-card"><div class="stat-number" id="approvedTasks">-</div><div class="stat-label">已通过</div></div>
        <div class="stat-card"><div class="stat-number" id="rejectedTasks">-</div><div class="stat-label">已驳回</div></div>
    </div>

    <!-- 最近的审核任务 -->
    <div class="panel">
        <div class="panel-title">📋 最近的审核任务</div>
        <div class="task-list" id="recentTasks">加载中...</div>
    </div>

    <!-- Agent 进化统计 -->
    <div class="panel">
        <div class="panel-title">🤖 Agent 进化统计</div>
        <div style="overflow-x: auto;">
            <table class="agent-table" id="agentTable">
                <thead><tr><th>Agent</th><th>学习数</th><th>进度</th><th>操作</th></tr></thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

    <!-- OpenClaw 系统状态 -->
    <div class="panel">
        <div class="panel-title">⚙️ OpenClaw 系统状态</div>
        <div id="systemStatus">加载中...</div>
    </div>

    <!-- 快捷导航 -->
    <div class="nav-links">
        <a href="/review/index.html" class="nav-card"><div class="nav-icon">📋</div><div class="nav-title">审核看板</div><div class="nav-desc">可视听化审核</div></a>
        <a href="/dashboard/index.html" class="nav-card"><div class="nav-icon">📊</div><div class="nav-title">数据看板</div><div class="nav-desc">统计分析</div></a>
        <a href="/joymate/frontend/nav.html" class="nav-card"><div class="nav-icon">🚀</div><div class="nav-title">JOY Mate</div><div class="nav-desc">智能体平台</div></a>
        <a href="/preview/deploy.html" class="nav-card"><div class="nav-icon">🔧</div><div class="nav-title">部署预览</div><div class="nav-desc">临时页面</div></a>
    </div>
</div>

<script>
    const API_URL = 'http://localhost:5005/api/admin';
    const STATS_API = 'http://localhost:5006/api/stats';

    async function loadTasks() {
        try {
            const resp = await fetch(`${API_URL}/tasks?_=${Date.now()}`);
            const tasks = await resp.json();
            
            const total = tasks.length;
            const pending = tasks.filter(t => t.status === 'pending').length;
            const approved = tasks.filter(t => t.status === 'approved').length;
            const rejected = tasks.filter(t => t.status === 'rejected').length;
            
            document.getElementById('totalTasks').innerText = total;
            document.getElementById('pendingTasks').innerText = pending;
            document.getElementById('approvedTasks').innerText = approved;
            document.getElementById('rejectedTasks').innerText = rejected;
            
            // 最近10个任务
            const recent = tasks.slice(-10).reverse();
            const recentHtml = recent.map(t => `
                <div class="task-item">
                    <div>
                        <strong>${escapeHtml(t.title || '无标题')}</strong>
                        <div style="font-size:11px; color:#666;">${t.submitter || 'unknown'} | ${t.created_at || ''}</div>
                    </div>
                    <span class="task-status status-${t.status}">${t.status === 'pending' ? '待审核' : (t.status === 'approved' ? '已通过' : '已驳回')}</span>
                </div>
            `).join('');
            document.getElementById('recentTasks').innerHTML = recent.length ? recentHtml : '<div style="padding:20px;text-align:center;">暂无任务</div>';
            
        } catch(e) {
            document.getElementById('recentTasks').innerHTML = '<div style="padding:20px;text-align:center;">加载失败</div>';
        }
    }

    async function loadAgentStats() {
        try {
            const resp = await fetch(`${STATS_API}/agents?_=${Date.now()}`);
            const agents = await resp.json();
            
            const maxLearn = Math.max(...agents.map(a => a.learn_count), 1);
            const tbody = document.querySelector('#agentTable tbody');
            tbody.innerHTML = agents.map(agent => `
                <tr>
                    <td>${getAgentIcon(agent.name)} ${agent.name}</td>
                    <td>${agent.learn_count}</td>
                    <td style="width: 150px;">
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: ${(agent.learn_count / maxLearn) * 100}%"></div>
                        </div>
                    </td>
                    <td><button class="btn-link" onclick="viewAgent('${agent.name}')">查看详情</button></td>
                </tr>
            `).join('');
        } catch(e) {
            console.error('加载Agent统计失败:', e);
        }
    }

    async function loadSystemStatus() {
        // 检查各服务状态
        const services = [
            { name: '审核 API', url: 'http://localhost:5005/api/admin/tasks', port: 5005 },
            { name: '数据看板 API', url: 'http://localhost:5006/api/stats/overview', port: 5006 },
            { name: 'Web 服务', url: 'http://localhost:8083/', port: 8083 }
        ];
        
        let html = '<table class="agent-table"><tr><th>服务</th><th>状态</th><th>端口</th></tr>';
        for (const svc of services) {
            try {
                const resp = await fetch(svc.url, { method: 'HEAD', cache: 'no-cache' });
                html += `<tr><td>${svc.name}</td><td style="color:#10b981;">✅ 运行中</td><td>${svc.port}</td></tr>`;
            } catch(e) {
                html += `<tr><td>${svc.name}</td><td style="color:#ef4444;">❌ 未运行</td><td>${svc.port}</td></tr>`;
            }
        }
        html += '</table>';
        document.getElementById('systemStatus').innerHTML = html;
    }

    function getAgentIcon(name) {
        const icons = { writer: '✍️', reviewer: '🔍', designer: '🎨', engineer: '🔧', 
                       spider: '🕷️', messenger: '💬', 'video-maker': '🎬', youtube: '📺', 
                       xiaohongshu: '📕', chief: '👑' };
        return icons[name] || '🤖';
    }

    function escapeHtml(text) {
        if (!text) return '';
        return String(text).replace(/[&<>]/g, m => m === '&' ? '&amp;' : (m === '<' ? '&lt;' : '&gt;'));
    }

    function viewAgent(agentName) {
        alert(`查看 ${agentName} 详情功能开发中\n可通过文件查看: ~/.openclaw/agents/${agentName}/evolution/LEARNINGS.md`);
    }

    async function loadAllData() {
        await loadTasks();
        await loadAgentStats();
        await loadSystemStatus();
    }

    loadAllData();
    setInterval(loadAllData, 30000);
</script>
</body>
</html>
<script>
fetch('http://localhost:8085/api/results')
  .then(res => res.json())
  .then(data => {
    const container = document.getElementById('resultsTable');
    if (container) {
      container.innerHTML = data.map(r => `
        <tr>
          <td>${r.id}</td>
          <td>${r.tenant}</td>
          <td>${r.task_type}</td>
          <td>${r.city}</td>
          <td style="color: ${r.status === 'success' ? 'green' : 'red'}">${r.status}</td>
          <td>${r.created_at}</td>
        </tr>
      `).join('');
    }
  });
</script>
<table id="resultsTable" border="1" style="width:100%; margin-top:20px;">
  <tr><th>ID</th><th>租户</th><th>任务类型</th><th>城市</th><th>状态</th><th>时间</th></tr>
</table>
