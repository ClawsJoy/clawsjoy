// ============================================
// 喇叭开关 - 即时生效，可中断语音
// ============================================
let SPEAKER_ON = true;
let currentAudio = null;  // 保存当前播放的音频

// 喇叭按钮
const speakerControlBtn = document.getElementById('speakBtn');
if (speakerControlBtn) {
    speakerControlBtn.style.opacity = '1';
    speakerControlBtn.style.borderColor = '#0ff';
    
    speakerControlBtn.onclick = () => {
        SPEAKER_ON = !SPEAKER_ON;
        
        // 如果关闭语音，立即停止当前播放
        if (!SPEAKER_ON && currentAudio) {
            currentAudio.pause();
            currentAudio.currentTime = 0;
            currentAudio = null;
        }
        
        // 更新 UI
        if (SPEAKER_ON) {
            speakerControlBtn.style.opacity = '1';
            speakerControlBtn.style.borderColor = '#0ff';
        } else {
            speakerControlBtn.style.opacity = '0.4';
            speakerControlBtn.style.borderColor = '#555';
        }
        
        // 提示（不占用语音通道）
        const tip = document.createElement('div');
        tip.textContent = SPEAKER_ON ? '🔊 语音已开启' : '🔇 语音已关闭';
        tip.style.cssText = 'position:fixed;bottom:100px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.7);color:#0ff;padding:4px 12px;border-radius:20px;font-size:12px;z-index:10001';
        document.body.appendChild(tip);
        setTimeout(() => tip.remove(), 800);
    };
}

// 可中断的语音回复函数
window.interruptableSpeak = async function(text) {
    if (!SPEAKER_ON) return;
    if (!text || text.includes('✅') || text.includes('❌')) return;
    
    const host = window.location.hostname;
    try {
        const res = await fetch(`http://${host}:9000/api/tts`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text: text })
        });
        if (res.ok) {
            const blob = await res.blob();
            const url = URL.createObjectURL(blob);
            // 停止当前播放
            if (currentAudio) {
                currentAudio.pause();
                currentAudio = null;
            }
            currentAudio = new Audio(url);
            currentAudio.play();
            currentAudio.onended = () => {
                URL.revokeObjectURL(url);
                if (currentAudio === this) currentAudio = null;
            };
        }
    } catch(e) {
        console.log("TTS 失败:", e);
    }
};

// 监听 AI 回复
const speakerObserver = new MutationObserver(() => {
    const lastMsg = document.querySelector('.msg.bot:last-child');
    if (lastMsg && !lastMsg.dataset.spoke) {
        lastMsg.dataset.spoke = 'true';
        const txt = lastMsg.innerText;
        if (txt && !txt.includes('✅')) {
            setTimeout(() => window.interruptableSpeak(txt), 200);
        }
    }
});
setTimeout(() => {
    const chatDiv = document.getElementById('chatArea');
    if (chatDiv) speakerObserver.observe(chatDiv, { childList: true, subtree: true });
}, 800);

console.log("✅ 喇叭开关已升级：即时生效，可中断当前语音");
</script>
<script>
(function() {
    const uploadBtn = document.getElementById('uploadBtn');
    const fileInput = document.getElementById('uploadFile');
    const uploadArea = document.querySelector('.upload-area');
    
    if (uploadBtn && fileInput) {
        // 移除原有事件，重新绑定
        const newBtn = uploadBtn.cloneNode(true);
        uploadBtn.parentNode.replaceChild(newBtn, uploadBtn);
        
        newBtn.onclick = function(e) {
            e.stopPropagation();
            if (fileInput.files.length > 0) {
                console.log('上传:', fileInput.files[0].name);
                alert('上传文件到资料库');
            } else {
                alert('请先选择文件');
            }
        };
    }
    
    if (uploadArea && fileInput) {
        uploadArea.onclick = function(e) {
            if (e.target === uploadBtn || e.target === document.getElementById('uploadBtn')) return;
            fileInput.click();
        };
    }
    
    console.log('✅ 上传按钮已修复');
})();
</script>
<script>
(function() {
    // 等待页面加载完成
    const fixUpload = function() {
        const uploadArea = document.querySelector('.upload-area');
        const fileInput = document.getElementById('uploadFile');
        let uploadBtn = document.getElementById('uploadBtn');
        
        if (!uploadArea || !fileInput) return;
        
        // 清除 upload-area 上的所有事件
        uploadArea.onclick = null;
        
        // 重建上传按钮（清除旧事件）
        if (uploadBtn) {
            const newBtn = uploadBtn.cloneNode(true);
            uploadBtn.parentNode.replaceChild(newBtn, uploadBtn);
            uploadBtn = newBtn;
        }
        
        // 重新绑定干净的事件
        uploadArea.onclick = function(e) {
            if (e.target === uploadBtn) return;
            fileInput.click();
        };
        
        if (uploadBtn) {
            uploadBtn.onclick = function(e) {
                e.stopPropagation();
                if (fileInput.files && fileInput.files.length > 0) {
                    const file = fileInput.files[0];
                    console.log('上传文件:', file.name);
                    alert('上传: ' + file.name);
                } else {
                    alert('请先选择文件');
                }
            };
        }
        
        // 文件选择变化提示
        fileInput.onchange = function(e) {
            if (e.target.files && e.target.files.length > 0) {
                console.log('已选择:', e.target.files[0].name);
            }
        };
        
        console.log('✅ 上传按钮已永久修复');
    };
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', fixUpload);
    } else {
        fixUpload();
    }
})();
</script>
<script>
(function() {
    const fixFileInput = function() {
        const fileInput = document.getElementById('uploadFile');
        if (!fileInput || fileInput._fixed) return;
        fileInput._fixed = true;
        
        // 保存原有样式
        const oldStyle = fileInput.style.cssText;
        
        // 创建新的 input 替换
        const newInput = document.createElement('input');
        newInput.type = 'file';
        newInput.id = 'uploadFile';
        newInput.multiple = true;
        newInput.style.cssText = oldStyle;
        
        // 复制属性
        if (fileInput.accept) newInput.accept = fileInput.accept;
        
        // 替换
        fileInput.parentNode.replaceChild(newInput, fileInput);
        
        // 绑定一次性成功的事件
        newInput.onchange = function(e) {
            if (e.target.files && e.target.files.length > 0) {
                console.log('✅ 已选择文件:', e.target.files[0].name);
            }
        };
        
        newInput.onclick = function(e) {
            e.stopPropagation();
        };
        
        console.log('✅ 文件选择器已永久修复（一次成功）');
    };
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', fixFileInput);
    } else {
        fixFileInput();
    }
})();
</script>
<script>
(function() {
    const fileInput = document.getElementById('uploadFile');
    const uploadBtn = document.getElementById('uploadBtn');
    const uploadArea = document.querySelector('.upload-area');

    if (fileInput && uploadBtn) {
        // 选择文件
        fileInput.onchange = function(e) {
            if (this.files.length > 0) {
                console.log('✅ 已选择:', this.files[0].name);
            }
        };
        
        // 上传
        uploadBtn.onclick = function(e) {
            e.stopPropagation();
            if (fileInput.files.length > 0) {
                const file = fileInput.files[0];
                console.log('📤 上传:', file.name);
                alert('上传成功: ' + file.name);
                fileInput.value = '';
            } else {
                alert('请先选择文件');
            }
        };
    }

    if (uploadArea && fileInput && uploadBtn) {
        // 移除区域点击干涉
        uploadArea.onclick = null;
    }

    console.log('✅ 上传功能已永久保存');
})();
</script>

<script>
(function() {
    setTimeout(function() {
        const uploadArea = document.querySelector(".upload-area");
        const fileInput = document.getElementById("uploadFile");
        const uploadBtn = document.getElementById("uploadBtn");
        if (uploadArea) {
            uploadArea.onclick = null;
            const newArea = uploadArea.cloneNode(true);
            uploadArea.parentNode.replaceChild(newArea, uploadArea);
        }
        const newInput = document.getElementById("uploadFile");
        const newBtn = document.getElementById("uploadBtn");
        if (newInput && newBtn) {
            newInput.onchange = function(e) {
                if (this.files.length > 0) console.log("✅ 已选择:", this.files[0].name);
            };
            newBtn.onclick = function(e) {
                e.stopPropagation();
                if (newInput.files.length > 0) {
                    alert("上传成功: " + newInput.files[0].name);
                    newInput.value = "";
                } else {
                    alert("请先点击文件框选择文件");
                }
            };
        }
        console.log("✅ 上传功能已永久保存（延迟执行）");
    }, 200);
})();
</script>
</body>
</html>
<script>
(function() {
    const uploadArea = document.querySelector('.upload-area');
    const fileInput = document.getElementById('uploadFile');
    const uploadBtn = document.getElementById('uploadBtn');

    if (uploadArea && fileInput) {
        // 禁用容器点击
        uploadArea.onclick = null;
        uploadArea.style.cursor = 'default';
    }

    if (fileInput && uploadBtn) {
        // 统一上传逻辑
        uploadBtn.onclick = function(e) {
            e.stopPropagation();
            if (fileInput.files && fileInput.files.length > 0) {
                const file = fileInput.files[0];
                console.log('📤 上传:', file.name);
                alert('上传成功: ' + file.name);
                fileInput.value = '';
            } else {
                alert('请先点击「选择文件」按钮选择文件');
            }
        };
        
        // 确保文件框自身能工作
        fileInput.onchange = function(e) {
            if (this.files.length > 0) {
                console.log('✅ 已选择:', this.files[0].name);
            }
        };
    }

    console.log('✅ 已禁用容器点击，上传功能统一');
})();
</script>
