<script>
// ============================================
// 强制修复所有按钮功能
// ============================================

// 确保 addMsg 函数存在
if (typeof addMsg !== 'function') {
    window.addMsg = function(role, text) {
        const chat = document.getElementById('chatArea');
        if (!chat) return;
        const div = document.createElement('div');
        div.className = 'msg ' + role;
        div.innerText = text;
        chat.appendChild(div);
        div.scrollIntoView({ behavior: 'smooth' });
    };
}

// 确保 sendMsg 函数存在
if (typeof sendMsg !== 'function') {
    window.sendMsg = async function() {
        const input = document.getElementById('textInput');
        const text = input.value.trim();
        if (!text) return;
        input.value = '';
        addMsg('user', text);
        addMsg('bot', '🤔 思考中...');
        try {
            const host = window.location.hostname;
            const res = await fetch(`http://${host}:8101/api/agent`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text, tenant_id: '1' })
            });
            const data = await res.json();
            const last = document.querySelectorAll('.msg.bot');
            if (last.length) last[last.length-1].remove();
            addMsg('bot', data.message || data.reply || '收到');
        } catch(e) {
            const last = document.querySelectorAll('.msg.bot');
            if (last.length) last[last.length-1].remove();
            addMsg('bot', '❌ 网络错误');
        }
    };
}

// 重新绑定发送按钮
const sendButton = document.querySelector('.input-row button');
const inputBox = document.getElementById('textInput');
if (sendButton) sendButton.onclick = () => sendMsg();
if (inputBox) inputBox.onkeypress = (e) => { if (e.key === 'Enter') sendMsg(); };

// 宣传片
const promoBtn = document.getElementById('promoBtn');
if (promoBtn) {
    promoBtn.onclick = () => {
        addMsg('user', '制作香港宣传片');
        addMsg('bot', '🎬 生成中...');
        const host = window.location.hostname;
        fetch(`http://${host}:8086/api/task/promo`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ city: '香港', tenant_id: '1' })
        }).then(res => res.json()).then(data => {
            const last = document.querySelectorAll('.msg.bot');
            if (last.length) last[last.length-1].remove();
            if (data.success) {
                addMsg('bot', '✅ 宣传片已生成');
                const videoDiv = document.createElement('div');
                videoDiv.className = 'msg bot';
                videoDiv.innerHTML = `<video controls style="max-width:100%; border-radius:8px" src="${data.video_url}"></video>`;
                document.getElementById('chatArea').appendChild(videoDiv);
            } else addMsg('bot', '❌ 生成失败');
        }).catch(() => {
            const last = document.querySelectorAll('.msg.bot');
            if (last.length) last[last.length-1].remove();
            addMsg('bot', '❌ 网络错误');
        });
    };
}

// 咖啡
const coffeeBtn = document.getElementById('coffeeBtn');
if (coffeeBtn) {
    coffeeBtn.onclick = () => {
        addMsg('user', '咖啡');
        addMsg('bot', '☕ 获取中...');
        const host = window.location.hostname;
        fetch(`http://${host}:8090/api/billing/balance?tenant_id=1`)
            .then(res => res.json())
            .then(data => {
                const last = document.querySelectorAll('.msg.bot');
                if (last.length) last[last.length-1].remove();
                if (data.balance) addMsg('bot', `☕ ${data.balance.map(s => s.name).join('、')}`);
                else addMsg('bot', '☕ 暂无店铺');
            }).catch(() => {
