# ClawsJoy runtime configuration template
# Copy to your environment or source it before starting services.

# Root path (auto-detected if empty)
CLAWSJOY_ROOT=/mnt/d/clawsjoy

# Core directories
CLAWSJOY_TENANTS_DIR=/mnt/d/clawsjoy/tenants
CLAWSJOY_DATA_DIR=/mnt/d/clawsjoy/data
CLAWSJOY_LOGS_DIR=/mnt/d/clawsjoy/logs
CLAWSJOY_TASK_QUEUE_DIR=/mnt/d/clawsjoy/tenants/queue
CLAWSJOY_LOG_APP_DIR=/mnt/d/clawsjoy/logs/app
CLAWSJOY_LOG_RUNNER_DIR=/mnt/d/clawsjoy/logs/runner
CLAWSJOY_LOG_AUDIT_DIR=/mnt/d/clawsjoy/logs/audit
CLAWSJOY_LOG_SYSTEM_DIR=/mnt/d/clawsjoy/logs/system
CLAWSJOY_LOG_ROTATE_COUNT=14
CLAWSJOY_LOG_ROTATE_SIZE=20M

# Service ports
CLAWSJOY_PORT_AUTH=8092
CLAWSJOY_PORT_TENANT=8088
CLAWSJOY_PORT_BILLING=8090
CLAWSJOY_PORT_TASK=8084
CLAWSJOY_PORT_JOYMATE=8080
CLAWSJOY_PORT_COFFEE=8085
CLAWSJOY_PORT_PROMO=8086
