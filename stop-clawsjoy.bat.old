@echo off
title ClawsJoy Shutdown
color 0C
echo ========================================
echo    Stopping all ClawsJoy services...
echo ========================================
echo.

echo [1/3] Stopping PM2 services...
wsl bash -c "pm2 stop chat-api tts"
echo [OK] PM2 services stopped
echo.

echo [2/3] Stopping Docker backend...
wsl bash -c "cd /mnt/d/clawsjoy && docker-compose down"
echo [OK] Docker services stopped
echo.

echo [3/3] Stopping Web UI...
taskkill /f /im python.exe >nul 2>&1
echo [OK] Web UI stopped
echo.

echo ========================================
echo    ALL SERVICES STOPPED
echo ========================================
pause
