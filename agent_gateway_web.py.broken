# ========== 安全护栏 ==========
from agent_core.safety.guardrails import safety_guard

@app.route('/api/chat/secure', methods=['POST'])
def secure_chat():
    import requests
    """带安全护栏的对话"""
    data = request.json
    user_id = data.get('user_id', 'anonymous')
    message = data.get('message', '')
    
    # 1. 输入安全检查
    safe, category, response = safety_guard.check_input(message)
    if not safe:
        return jsonify({
            'success': False,
            'error': response,
            'category': category,
            'blocked': True
        }), 403
    
    # 2. 正常处理
    try:
        resp = requests.post("http://localhost:11434/api/generate",
            json={"model": "llama3.2:3b", "prompt": message, "stream": False},
            timeout=60)
        output = resp.json().get('response', '')
        
        # 3. 输出安全检查
        safe_out, error_msg = safety_guard.check_output(output)
        if not safe_out:
            return jsonify({
                'success': False,
                'error': error_msg,
                'blocked': True
            }), 403
        
        # 记录正常对话
        return jsonify({
            'success': True,
            'message': output,
            'blocked': False
        })
    except Exception as e:
        return jsonify({'success': False, 'error': str(e)}), 500

@app.route('/api/safety/stats', methods=['GET'])
def safety_stats():
    """获取安全统计"""
    return jsonify(safety_guard.get_stats())

# ========== 文件处理 API ==========
from skills.file_processor import skill as file_skill

def upload_file():
    """上传文件"""
    if 'file' not in request.files:
        return jsonify({'error': 'No file'}), 400
    
    file = request.files['file']
    if file.filename == '':
        return jsonify({'error': 'No filename'}), 400
    
    # 保存文件
    from pathlib import Path
    upload_dir = Path("data/uploads")
    upload_dir.mkdir(parents=True, exist_ok=True)
    save_path = upload_dir / file.filename
    file.save(save_path)
    
    return jsonify({
        'success': True,
        'filename': file.filename,
        'size': save_path.stat().st_size,
        'path': str(save_path)
    })

def read_file(filename):
    """读取上传的文件"""
    from pathlib import Path
    file_path = Path("data/uploads") / filename
    result = file_skill.read_file(str(file_path))
    return jsonify(result)

def list_files():
    """列出上传的文件"""
    result = file_skill.list_files()
    return jsonify(result)

# ========== 文件处理 API ==========
from skills.file_processor import skill as file_skill
from pathlib import Path

def list_uploaded_files():
    """列出上传的文件"""
    result = file_skill.list_files()
    return jsonify(result)

def upload_file():
    """上传文件"""
    if 'file' not in request.files:
        return jsonify({'error': 'No file'}), 400
    
    file = request.files['file']
    if file.filename == '':
        return jsonify({'error': 'No filename'}), 400
    
    upload_dir = Path("data/uploads")
    upload_dir.mkdir(parents=True, exist_ok=True)
    save_path = upload_dir / file.filename
    file.save(save_path)
    
    return jsonify({
        'success': True,
        'filename': file.filename,
        'size': save_path.stat().st_size,
        'path': str(save_path)
    })

def read_uploaded_file(filename):
    """读取上传的文件"""
    file_path = Path("data/uploads") / filename
    if not file_path.exists():
        return jsonify({'error': 'File not found'}), 404
    result = file_skill.read_file(str(file_path))
    return jsonify(result)




