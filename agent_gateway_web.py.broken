# ========== 多智能体代理（调用独立服务）==========
import requests

@app.route('/api/multi/agents', methods=['GET'])
def multi_agents_proxy():
    try:
        resp = requests.get('http://localhost:5006/agents', timeout=5)
        return jsonify(resp.json())
    except Exception as e:
        return jsonify({'error': str(e), 'agents': []})

@app.route('/api/multi/execute', methods=['POST'])
def multi_execute_proxy():
    try:
        resp = requests.post('http://localhost:5006/execute', 
                            json=request.json, timeout=30)
        return jsonify(resp.json())
    except Exception as e:
        return jsonify({'error': str(e), 'results': {}})
