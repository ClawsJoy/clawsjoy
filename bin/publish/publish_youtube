#!/bin/bash
# YouTube 发布专用

TITLE="$1"
DESCRIPTION="$2"
FILENAME="$HOME/clawsjoy/outbox/youtube_$(date +%Y%m%d_%H%M%S_%N).youtube.json"

mkdir -p "$HOME/clawsjoy/outbox"

cat > "$FILENAME" << JSON
{
  "title": "$TITLE",
  "description": "$DESCRIPTION",
  "platform": "youtube",
  "submitter": "youtube",
  "created_at": "$(date -Iseconds)"
}
JSON

echo "✅ YouTube 发布任务已提交: $TITLE"
