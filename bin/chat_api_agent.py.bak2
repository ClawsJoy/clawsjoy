#!/usr/bin/env python3
"""Chat API - 简化稳定版"""

import json
import requests
from http.server import HTTPServer, BaseHTTPRequestHandler

OLLAMA_URL = "http://localhost:11434/api/generate"
PORT = 8101

class Handler(BaseHTTPRequestHandler):
    
    def do_OPTIONS(self):
        self.send_response(200)
        self.send_header('Access-Control-Allow-Origin', '*')
        self.send_header('Access-Control-Allow-Methods', 'POST, OPTIONS')
        self.send_header('Access-Control-Allow-Headers', 'Content-Type')
        self.end_headers()
    
    def do_POST(self):
        if self.path == '/api/agent':
            try:
                length = int(self.headers.get('Content-Length', 0))
                data = json.loads(self.rfile.read(length))
                user_input = data.get('text', data.get('message', ''))
                
                if not user_input:
                    self._send_json({'type': 'text', 'message': '请输入消息'})
                    return
                
                print(f"📝 用户: {user_input[:50]}")
                
                # 调用 Ollama
                reply = self._call_ollama(user_input)
                self._send_json({'type': 'text', 'message': reply})
                
            except Exception as e:
                print(f"错误: {e}")
                self._send_json({'type': 'text', 'message': f'服务异常'})
        else:
            self.send_error(404)
    
    def _call_ollama(self, prompt):
        try:
            payload = {
                "model": "qwen:0.5b",
                "prompt": f"用户: {prompt}\n助手:",
                "stream": False,
                "options": {"num_predict": 512, "temperature": 0.7}
            }
            
            resp = requests.post(OLLAMA_URL, json=payload, timeout=60)
            
            if resp.status_code == 200:
                result = resp.json()
                reply = result.get('response', '').strip()
                # 清理回复
                reply = reply.split('用户:')[0].split('助手:')[-1].strip()
                return reply if reply else "收到消息！"
            else:
                return f"Ollama 错误: {resp.status_code}"
                
        except requests.exceptions.Timeout:
            return "请求超时，请稍后再试"
        except Exception as e:
            print(f"Ollama 调用失败: {e}")
            return "服务暂时不可用"
    
    def _send_json(self, data):
        self.send_response(200)
        self.send_header('Content-Type', 'application/json')
        self.send_header('Access-Control-Allow-Origin', '*')
        self.end_headers()
        self.wfile.write(json.dumps(data, ensure_ascii=False).encode())
    
    def log_message(self, format, *args):
        pass

if __name__ == '__main__':
    print(f"🤖 Chat API 启动在端口 {PORT}")
    print(f"📍 http://localhost:{PORT}/api/agent")
    HTTPServer(('0.0.0.0', PORT), Handler).serve_forever()
