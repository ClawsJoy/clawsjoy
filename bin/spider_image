#!/bin/bash
# Spider 真正采集图片（从免费图库）

KEYWORD="$1"
COUNT="${2:-5}"
OUTPUT_DIR="$HOME/.openclaw/web/images/${KEYWORD// /_}"

mkdir -p "$OUTPUT_DIR"

echo "🕷️ Spider 开始采集: $KEYWORD"

# 使用 Pexels 或 Unsplash 免费 API（需要申请 key）
# 这里先用 Lorem Picsum（免费、无需 key、真实图片）
for i in $(seq 1 $COUNT); do
    wget -q -O "$OUTPUT_DIR/${KEYWORD}_${i}.jpg" "https://picsum.photos/800/600?random=$i"
    echo "✅ 已下载: ${KEYWORD}_${i}.jpg"
done

echo "📁 保存位置: $OUTPUT_DIR"
echo "✅ 采集完成，共 $COUNT 张真实图片"
