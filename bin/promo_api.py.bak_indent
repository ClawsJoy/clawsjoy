#!/usr/bin/env python3
"""Promo API - 多图轮播版"""

import json

def get_search_keyword(city, style, topic):
    """获取 Unsplash 搜索关键词"""
    import random
    
    real_terms = [
        "real street photography",
        "documentary style", 
        "on location shooting",
        "real life photography"
    ]
    
    topic_lower = topic.lower()
    if any(k in topic_lower for k in ["优才", "人才", "移民"]):
        scene = "government building"
    elif any(k in topic_lower for k in ["留学", "大学"]):
        scene = "university campus"
    elif any(k in topic_lower for k in ["生活", "租房"]):
        scene = "city street"
    else:
        scene = "cityscape"
    
    base = random.choice(real_terms)
    return f"{city} {scene} {base}"
