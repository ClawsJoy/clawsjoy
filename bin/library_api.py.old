#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""ClawsJoy 资料库 API - 修复版"""

import os
import json
import sqlite3
import mimetypes
from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.parse import urlparse, parse_qs
import cgi

PORT = 8098
BASE_DIR = "/home/flybo/clawsjoy/data"
LIBRARY_DIR = os.path.join(BASE_DIR, "tenants/default/library")
DB_PATH = os.path.join(BASE_DIR, "library.db")

os.makedirs(LIBRARY_DIR, exist_ok=True)


class LibraryHandler(BaseHTTPRequestHandler):
    protocol_version = 'HTTP/1.1'

    def send_cors_headers(self):
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, DELETE, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")

    def do_OPTIONS(self):
        self.send_response(200)
        self.send_cors_headers()
        self.end_headers()

    def do_GET(self):
        parsed = urlparse(self.path)
        path = parsed.path

        if path == "/api/library/list":
            self.handle_list()
        elif path == "/api/library/preview":
            self.handle_preview(parsed.query)
        elif path == "/api/library/search":
            self.handle_search(parsed.query)
        else:
            self.send_json(404, {"error": "not found"})

    def do_POST(self):
        if self.path == "/api/library/upload":
            self.handle_upload()
        else:
            self.send_json(404, {"error": "not found"})

    def do_DELETE(self):
        if self.path.startswith("/api/library/delete/"):
            self.handle_delete()
        else:
            self.send_json(404, {"error": "not found"})

    def handle_list(self):
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        cursor.execute("""
            SELECT id, filename, filesize, filetype, created_at 
            FROM assets WHERE tenant_id='default' 
            ORDER BY created_at DESC
        """)
        rows = cursor.fetchall()
        conn.close()

        files = [{"id": r[0], "filename": r[1], "size": r[2], "type": r[3], "created": r[4]} for r in rows]
        self.send_json(200, {"success": True, "files": files})

    def handle_preview(self, query):
        params = parse_qs(query)
        filename = params.get("filename", [""])[0]
        if not filename:
            self.send_json(400, {"error": "filename required"})
            return

        filepath = os.path.join(LIBRARY_DIR, filename)
        if not os.path.exists(filepath):
            self.send_json(404, {"error": "file not found"})
            return

        # 更新访问时间
        conn = sqlite3.connect(DB_PATH)
        conn.execute("UPDATE assets SET last_access=strftime('%s','now') WHERE filename=?", (filename,))
        conn.commit()
        conn.close()

        mime = mimetypes.guess_type(filepath)[0] or "application/octet-stream"
        with open(filepath, "rb") as f:
            self.send_response(200)
            self.send_header("Content-Type", mime)
            self.end_headers()
            self.wfile.write(f.read())

    def handle_search(self, query):
        params = parse_qs(query)
        keyword = params.get("q", [""])[0]
        if not keyword:
            self.send_json(400, {"error": "q required"})
            return

        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        cursor.execute(
            "SELECT id, filename, filesize, filetype FROM assets WHERE filename LIKE ?",
            (f"%{keyword}%",)
        )
        rows = cursor.fetchall()
        conn.close()

        files = [{"id": r[0], "filename": r[1], "size": r[2], "type": r[3]} for r in rows]
        self.send_json(200, {"success": True, "files": files})

    def handle_upload(self):
        form = cgi.FieldStorage(
            fp=self.rfile,
            headers=self.headers,
            environ={'REQUEST_METHOD': 'POST', 'CONTENT_TYPE': self.headers['Content-Type']}
        )

        if 'file' not in form:
            self.send_json(400, {"error": "no file"})
            return

        file_item = form['file']
        filename = os.path.basename(file_item.filename)
        filepath = os.path.join(LIBRARY_DIR, filename)

        # 保存文件
        with open(filepath, "wb") as f:
            f.write(file_item.file.read())

        # 记录到数据库
        filetype = filename.split(".")[-1].lower() if "." in filename else "unknown"
        filesize = os.path.getsize(filepath)
        mime = mimetypes.guess_type(filename)[0] or "application/octet-stream"

        conn = sqlite3.connect(DB_PATH)
        conn.execute("""
            INSERT INTO assets (filename, filepath, filesize, filetype, mime_type, tenant_id, created_at)
            VALUES (?, ?, ?, ?, ?, 'default', strftime('%s','now'))
        """, (filename, filepath, filesize, filetype, mime))
        conn.commit()
        conn.close()

        self.send_json(200, {"success": True, "filename": filename, "size": filesize})

    def handle_delete(self):
        filename = self.path.split("/")[-1]
        filepath = os.path.join(LIBRARY_DIR, filename)

        if os.path.exists(filepath):
            os.remove(filepath)

        conn = sqlite3.connect(DB_PATH)
        conn.execute("DELETE FROM assets WHERE filename=?", (filename,))
        conn.commit()
        conn.close()

        self.send_json(200, {"success": True, "deleted": filename})

    def send_json(self, code, data):
        self.send_response(code)
        self.send_cors_headers()
        self.send_header("Content-Type", "application/json")
        self.end_headers()
        self.wfile.write(json.dumps(data).encode())

    def log_message(self, fmt, *args):
        print(f"[Library] {fmt % args}")


if __name__ == "__main__":
    server = HTTPServer(("0.0.0.0", PORT), LibraryHandler)
    print(f"✅ 资料库 API 启动: http://localhost:{PORT}")
    server.serve_forever()
