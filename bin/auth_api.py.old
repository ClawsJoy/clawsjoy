#!/usr/bin/env python3
"""ClawsJoy 认证服务。

提供最小认证能力：健康检查、登录、注册。
数据持久化在 SQLite，登录成功后签发 JWT。
"""

import json
import sqlite3
import hashlib
import jwt
from datetime import datetime, timedelta
from pathlib import Path
from http.server import HTTPServer, BaseHTTPRequestHandler
import time
from settings import DATA_DIR, PORT_AUTH
from py_logging import get_logger

SECRET_KEY = "clawsjoy-secret-2026"
DB_PATH = str(DATA_DIR / "auth.db")
LOGGER = get_logger("auth_api")

def init_db():
    """初始化认证数据库，并在首次启动时创建默认管理员。"""
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        id INTEGER PRIMARY KEY,
        username TEXT UNIQUE,
        password TEXT,
        tenant_id TEXT,
        role TEXT
    )''')
    # 创建默认管理员
    c.execute("SELECT COUNT(*) FROM users")
    if c.fetchone()[0] == 0:
        pwd = hashlib.sha256("admin123".encode()).hexdigest()
        c.execute("INSERT INTO users (username, password, tenant_id, role) VALUES (?,?,?,?)",
                  ("admin", pwd, "0", "admin"))
        conn.commit()
    conn.close()
    LOGGER.info("数据库初始化完成")

def hash_pw(pw):
    """对明文密码做 SHA256 哈希。"""
    return hashlib.sha256(pw.encode()).hexdigest()

def gen_token(username, tenant_id, role):
    """生成 7 天有效期 JWT。"""
    payload = {
        "username": username,
        "tenant_id": tenant_id,
        "role": role,
        "exp": datetime.utcnow() + timedelta(days=7)
    }
    return jwt.encode(payload, SECRET_KEY, algorithm="HS256")

class Handler(BaseHTTPRequestHandler):
    """认证 API 处理器。"""

    def do_OPTIONS(self):
        """处理浏览器 CORS 预检请求。"""
        self.send_response(200)
        self.send_header('Access-Control-Allow-Origin', '*')
        self.send_header('Access-Control-Allow-Methods', 'GET, POST, OPTIONS')
        self.send_header('Access-Control-Allow-Headers', 'Content-Type')
        self.end_headers()
    
    def do_GET(self):
        """处理只读接口。"""
        if self.path == '/api/auth/health':
            self.send_json({"status": "ok"})
        else:
            self.send_error(404)
    
    def do_POST(self):
        """处理写接口：登录与注册。"""
        length = int(self.headers.get('Content-Length', 0))
        data = json.loads(self.rfile.read(length))
        
        if self.path == '/api/auth/login':
            # 通过用户名 + 哈希密码校验身份。
            conn = sqlite3.connect(DB_PATH)
            c = conn.cursor()
            c.execute("SELECT username, tenant_id, role FROM users WHERE username=? AND password=?",
                      (data.get('username'), hash_pw(data.get('password', ''))))
            user = c.fetchone()
            conn.close()
            if user:
                # 登录成功后返回令牌与基础用户信息。
                token = gen_token(user[0], user[1], user[2])
                self.send_json({"success": True, "token": token, "user": {"name": user[0], "tenant_id": user[1], "role": user[2]}})
            else:
                self.send_json({"success": False, "error": "用户名或密码错误"}, 401)
        elif self.path == '/api/auth/register':
            # 新用户默认角色为 user。
            conn = sqlite3.connect(DB_PATH)
            c = conn.cursor()
            try:
                c.execute("INSERT INTO users (username, password, tenant_id, role) VALUES (?,?,?,?)",
                          (data.get('username'), hash_pw(data.get('password', '')), data.get('tenant_id', '1'), 'user'))
                conn.commit()
                self.send_json({"success": True})
            except Exception as e:
                self.send_json({"success": False, "error": str(e)}, 400)
            conn.close()
        else:
            self.send_error(404)
    
    def send_json(self, data, status=200):
        """统一 JSON 响应并附带基础 CORS 头。"""
        self.send_response(status)
        self.send_header('Content-Type', 'application/json')
        self.send_header('Access-Control-Allow-Origin', '*')
        self.end_headers()
        self.wfile.write(json.dumps(data).encode())
    
    def log_message(self, *args):
        """记录标准访问日志。"""
        LOGGER.info(args[0] % args[1:])

if __name__ == "__main__":
    init_db()
    port = PORT_AUTH
    LOGGER.info("Auth API started: http://localhost:%s", port)
    LOGGER.info("Route: POST /api/auth/login")
    HTTPServer(("0.0.0.0", port), Handler).serve_forever()
