      {
        "learned_at": "2026-05-08T22:22:08.026221",
        "content": {
          "analysis": "\u5728\u4f7f\u7528YouTube API\u8fdb\u884c\u6570\u636e\u64cd\u4f5c\u65f6\uff0c\u9700\u8981\u901a\u8fc7\u914d\u7f6eOAuth 2.0\u5ba2\u6237\u7aefID\u548c\u5bc6\u94a5\u6765\u83b7\u53d6API\u51ed\u8bc1\u3002\u5982\u679c\u7f3a\u5931\u6216\u9519\u8bef\u914d\u7f6e\u8fd9\u4e9b\u4fe1\u606f\uff0c\u4f1a\u5bfc\u81f4\u65e0\u6cd5\u8bbf\u95eeAPI\u63a5\u53e3\u3002",
          "solution": "\u786e\u4fdd\u4f60\u5df2\u7ecf\u4eceGoogle Cloud Platform\u521b\u5efa\u4e86\u6709\u6548\u7684OAuth 2.0\u5ba2\u6237\u7aefID\u5e76\u8bbe\u7f6e\u4e86\u76f8\u5e94\u7684\u5bc6\u94a5\u3002\u7136\u540e\u4f7f\u7528\u6b63\u786e\u7684\u5ba2\u6237\u7aefID\u548c\u5bc6\u94a5\u8fdb\u884cAPI\u8bf7\u6c42\u3002\u4f60\u53ef\u4ee5\u901a\u8fc7YouTube API\u63a7\u5236\u53f0\u6765\u83b7\u53d6\u548c\u7ba1\u7406\u4f60\u7684\u51ed\u8bc1\u3002",
          "prevention": "\u5b9a\u671f\u68c0\u67e5\u5e76\u66f4\u65b0\u4f60\u7684OAuth 2.0\u5ba2\u6237\u7aef\u4fe1\u606f\uff0c\u786e\u4fdd\u5b83\u4eec\u662f\u6700\u65b0\u7684\u4e14\u6ca1\u6709\u6cc4\u9732\u7684\u98ce\u9669\u3002\u540c\u65f6\uff0c\u4e3a\u4e86\u9632\u6b62\u51ed\u8bc1\u88ab\u76d7\u7528\u6216\u88ab\u6ee5\u7528\uff0c\u5e94\u8bbe\u7f6e\u5f3a\u5bc6\u7801\uff0c\u5e76\u9650\u5236\u5bf9\u8fd9\u4e9b\u654f\u611f\u4fe1\u606f\u7684\u8bbf\u95ee\u6743\u9650\u3002",
          "commands": [
            "google-cloud-console",
            "youtube-api-control-panel"
          ]
        },
        "context": "\u9700\u8981\u914d\u7f6eYouTube API\u51ed\u8bc1\uff0c\u5305\u62ecOAuth 2.0\u5ba2\u6237\u7aefID\u548c\u5bc6\u94a5"
      },
      {
        "learned_at": "2026-05-08T22:22:12.691272",
        "content": {
          "analysis": "\u7528\u6237\u5728\u914d\u7f6eYouTube API\u51ed\u8bc1\u65f6\u9047\u5230\u4e86\u95ee\u9898\uff0c\u9700\u8981\u914d\u7f6eOAuth 2.0\u5ba2\u6237\u7aefID\u548c\u5bc6\u94a5\u3002",
          "solution": "\u4e3a\u4e86\u89e3\u51b3\u8fd9\u4e2a\u95ee\u9898\uff0c\u60a8\u9700\u8981\u9996\u5148\u4eceGoogle Cloud Platform\uff08GCP\uff09\u521b\u5efa\u6216\u83b7\u53d6\u4e00\u4e2a\u6709\u6548\u7684OAuth 2.0\u5ba2\u6237\u7aefID\u3002\u767b\u5f55\u5230\u60a8\u7684Google Developers Console\u540e\uff0c\u627e\u5230\u5e76\u9009\u62e9\u60a8\u60f3\u8981\u4f7f\u7528\u7684\u9879\u76ee\uff0c\u7136\u540e\u70b9\u51fb\u5de6\u4fa7\u7684\u201cAPIs & Services\u201d -> \u201cCredentials\u201d\u3002\u5728\u8be5\u9875\u9762\u4e0a\uff0c\u60a8\u53ef\u4ee5\u521b\u5efa\u4e00\u4e2a\u65b0\u7684OAuth 2.0\u5ba2\u6237\u7aefID\u3002\u63a5\u4e0b\u6765\u586b\u5199\u76f8\u5173\u4fe1\u606f\uff08\u5982\u5e94\u7528\u540d\u79f0\uff09\uff0c\u7136\u540e\u6839\u636e\u9700\u8981\u6dfb\u52a0\u6743\u9650\u4ee5\u8bbf\u95eeYouTube API\u3002\u786e\u8ba4\u8bbe\u7f6e\u5b8c\u6210\u540e\uff0c\u60a8\u5c06\u83b7\u5f97\u4e00\u4e2a\u5305\u542bClient ID\u548cClient Secret\u7684\u51ed\u8bc1\u6587\u4ef6\u3002\u8fd9\u4e9b\u4fe1\u606f\u662f\u914d\u7f6eYouTube API\u6240\u9700\u8981\u7684\u3002",
          "prevention": "\u4e3a\u4e86\u9632\u6b62\u518d\u6b21\u53d1\u751f\u7c7b\u4f3c\u7684\u95ee\u9898\uff0c\u5efa\u8bae\u5b9a\u671f\u68c0\u67e5\u5e76\u66f4\u65b0\u60a8\u7684OAuth 2.0\u5ba2\u6237\u7aefID\u548c\u5bc6\u94a5\u3002\u540c\u65f6\uff0c\u786e\u4fdd\u5728\u83b7\u53d6\u8fd9\u4e9b\u51ed\u636e\u540e\u59a5\u5584\u4fdd\u7ba1\uff0c\u5e76\u9075\u5faaGoogle\u7684\u5b89\u5168\u6307\u5357\u6765\u4fdd\u62a4\u60a8\u7684API\u5b89\u5168\u3002",
          "commands": [
            "\u767b\u5f55\u5230Google Developers Console",
            "\u521b\u5efa\u4e00\u4e2a\u65b0\u9879\u76ee\u6216\u9009\u62e9\u73b0\u6709\u9879\u76ee",
            "\u8fdb\u5165\u201cAPIs & Services\u201d -> \u201cCredentials\u201d\uff0c\u70b9\u51fb\u201cCreate client ID and client secret\u201d\uff0c\u6839\u636e\u9700\u8981\u586b\u5199\u76f8\u5173\u4fe1\u606f\u5e76\u521b\u5efa\u5ba2\u6237\u7aefID",
            "\u786e\u8ba4\u8bbe\u7f6e\u540e\u83b7\u53d6Client ID\u548cClient Secret"
          ]
        },
