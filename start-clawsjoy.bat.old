@echo off
title ClawsJoy All-in-One Startup
color 0A
echo ========================================
echo    ClawsJoy All-in-One Startup
echo ========================================
echo.

echo [1/5] Starting Docker backend...
wsl bash -c "cd /mnt/d/clawsjoy && docker-compose up -d"
echo [OK] Docker services started
echo.

echo [2/5] Starting PM2 services (Chat API, TTS)...
wsl bash -c "pm2 resurrect 2>/dev/null || pm2 start /mnt/d/clawsjoy/bin/chat_api_agent.py --name chat-api --interpreter python3"
wsl bash -c "pm2 start /mnt/d/clawsjoy/bin/tts_server_stable.py --name tts --interpreter python3 2>/dev/null"
wsl bash -c "pm2 save"
echo [OK] PM2 services started
echo.

echo [3/5] Ensuring Ollama is running...
wsl bash -c "pgrep -f 'ollama serve' || nohup ollama serve > /tmp/ollama.log 2>&1 &"
echo [OK] Ollama is running
echo.

echo [4/5] Starting Web UI...
wsl bash -c "pkill -f 'http.server 8082' 2>/dev/null"
start /min python -m http.server 8082 --directory D:\clawsjoy\web
timeout /t 2 /nobreak >nul
echo [OK] Web UI started on port 8082
echo.

echo [5/5] Opening browser...
start http://localhost:8082

echo.
echo ========================================
echo    ALL SERVICES STARTED!
echo ========================================
echo.
echo    Web UI: http://localhost:8082
echo    Chat API: http://localhost:8101
echo    TTS: http://localhost:9000
echo    Ollama: http://localhost:11434
echo.
echo    PM2 commands: pm2 status, pm2 logs, pm2 monit
echo.
echo    Services are running in background.
echo    Close this window will NOT stop services.
echo.
echo ========================================
pause
