# ========== 生成并上传联动 ==========
def generate_and_upload(self, topic, duration=30):
    """生成视频并自动上传到 YouTube"""
    import requests
    import subprocess
    
    # 1. 检查 YouTube 是否已配置
    if not hasattr(self, 'secret_filter') or not self.secret_filter.has_secret("youtube_token"):
        return {"success": False, "message": "请先配置 YouTube（说：帮我配置 YouTube）"}
    
    # 2. 调用 Promo API 生成视频
    try:
        print(f"🎬 正在生成 {topic} 宣传片...")
        resp = requests.post("http://localhost:8108/api/promo/make", 
                            json={"topic": topic, "duration": duration, "purpose": "youtube"},
                            timeout=180)
        if resp.status_code != 200:
            return {"success": False, "message": f"视频生成失败: HTTP {resp.status_code}"}
        
        video_data = resp.json()
        if not video_data.get("success"):
            return {"success": False, "message": video_data.get("error", "视频生成失败")}
        
        video_url = video_data.get("video_url")
        print(f"✅ 视频生成完成: {video_url}")
    except Exception as e:
        return {"success": False, "message": f"视频生成异常: {str(e)}"}
    
    # 3. 上传到 YouTube
    try:
        print("📤 正在上传到 YouTube...")
        result = subprocess.run(
            ["python3", "/mnt/d/clawsjoy/agents/youtube_uploader.py", "--tenant", self.tenant_id, "--title", f"{topic}宣传片"],
            capture_output=True, text=True, timeout=300
        )
        
        if result.returncode == 0:
            return {
                "success": True,
                "message": "✅ 视频已生成并上传到 YouTube",
                "video_url": video_url,
                "youtube_result": result.stdout
            }
        else:
            return {
                "success": False,
                "message": f"视频已生成但上传失败: {result.stderr}",
                "video_url": video_url
            }
    except Exception as e:
        return {
            "success": False,
            "message": f"视频已生成但上传异常: {str(e)}",
            "video_url": video_url
        }

def upload_to_youtube(self):
    """上传视频到 YouTube"""
    import subprocess
    try:
        result = subprocess.run(
            ["python3", "/mnt/d/clawsjoy/agents/youtube_uploader.py", "--tenant", self.tenant_id],
            capture_output=True, text=True, timeout=300
        )
        if result.returncode == 0:
            return {"success": True, "message": "✅ 视频已上传", "output": result.stdout}
        return {"success": False, "message": f"上传失败: {result.stderr}"}
    except Exception as e:
        return {"success": False, "message": f"上传异常: {str(e)}"}
